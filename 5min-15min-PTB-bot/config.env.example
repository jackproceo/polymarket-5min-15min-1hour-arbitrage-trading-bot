# =============================================================================
# PTB Bot — config.env.example
# Copy this file to config.env and fill in your credentials.
#   cp config.env.example config.env
# NEVER commit config.env to git!
# =============================================================================

# ── WALLET (REQUIRED) ──────────────────────────────────────────────────────
PRIVATE_KEY=0x_your_private_key_here
FUNDER_ADDRESS=
SIGNATURE_TYPE=2

# ── POLYGON NETWORK ───────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com
CHAIN_ID=137

# ── POLYMARKET API (REQUIRED) ─────────────────────────────────────────────
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_api_passphrase

# ── TRADING ───────────────────────────────────────────────────────────────
BTC_MARKET_MINUTES=5       # 5 or 15
AUTO_TRADE=false           # Start with false; enable after simulation testing
SIMULATION_MODE=true       # Start in simulation mode
TRADE_AMOUNT=5             # USDC per buy

# ── WEB DASHBOARD ─────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=5080

# ── TELEGRAM (OPTIONAL) ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── PROXY (OPTIONAL) ──────────────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=

# ── TRIGGERS (adjust after simulation testing) ────────────────────────────
# See README.md for condition_1 through condition_4 parameter details
CONDITION_1_ENABLED=true
CONDITION_1_TIME_MIN=120
CONDITION_1_TIME_MAX=300
CONDITION_1_DIFF_MIN=50
CONDITION_1_DIFF_MAX=500
CONDITION_1_PROB_MIN=0.40
CONDITION_1_PROB_MAX=0.80

# ── RISK ──────────────────────────────────────────────────────────────────
STOP_LOSS_PROB_PCT=0.30
TAKE_PROFIT_RR=2.0
TAKE_PROFIT_CAP=0.95
MARKET_DATA_MAX_LAG_SEC=30
LOOP_INTERVAL_SEC=2
