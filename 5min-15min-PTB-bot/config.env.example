# =============================================================================
# PTB Bot — 配置参数示例文件 (config.env.example)
# 复制此文件为 config.env 后填入真实参数
#   cp config.env.example config.env
# 切勿将 config.env 提交到 Git！
# =============================================================================


# ── 钱包配置 (必填) ─────────────────────────────────────────────────────────
# 交易账户的 Polygon 链私钥（含 0x 前缀）
# 安全提示：私钥即资产，切勿泄露、切勿提交到 Git！
PRIVATE_KEY=0x_your_private_key_here

# 资金地址：Proxy 钱包模式下实际持有资金的地址
# 如果使用普通钱包（非 Proxy），留空则自动使用 PRIVATE_KEY 对应的地址
FUNDER_ADDRESS=

# CLOB 签名类型：2 = POLY_PROXY_712 (Polygon Proxy EIP-712), 1 = EOA
# Polymarket 推荐使用 2，非 Proxy 钱包使用 1
SIGNATURE_TYPE=2


# ── Polygon 网络 ────────────────────────────────────────────────────────────
# Polygon RPC 节点 URL（建议使用自己的 Infura/Alchemy 节点以提高稳定性）
# 公共 RPC 有速率限制，高频交易容易失败
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygon 链 ID (137 = Polygon Mainnet, 80002 = Amoy 测试网)
# 注意：当前代码未读取此变量，仅供参考
CHAIN_ID=137


# ── Polymarket CLOB API (必填) ──────────────────────────────────────────────
# 从 Polymarket Dashboard → API → Create API Key 获取
# 参考：https://docs.polymarket.com/api/overview
POLY_BUILDER_API_KEY=your_api_key
POLY_BUILDER_SECRET=your_api_secret
POLY_BUILDER_PASSPHRASE=your_api_passphrase

# 中继器 URL（默认使用 Polymarket 官方中继器）
RELAYER_URL=https://relayer-v2.polymarket.com

# 中继器交易类型：SAFE (推荐) 或 EOA
# SAFE = 通过中继器合约发送交易（支持 Gas 补贴）
# EOA  = 直接钱包签名发送（需自己有 MATIC 付 Gas）
RELAYER_TX_TYPE=SAFE


# ── 交易基础配置 ────────────────────────────────────────────────────────────
# BTC 市场数据时间窗口（分钟）：5 或 15
# 5  = 使用 5 分钟 K 线数据（适合短线、高频率策略）
# 15 = 使用 15 分钟 K 线数据（适合中长线策略）
BTC_MARKET_MINUTES=5

# 是否启用自动开仓：false（测试用，仅模拟不真实下单）
# 务必先在模拟模式下验证策略表现，再开启真实交易
AUTO_TRADE=false

# 模拟模式：true = 不下真实订单，仅打印交易决策日志
# 建议首次运行保持 true，观察策略表现符合预期后再关闭
SIMULATION_MODE=true

# 每笔开仓买入金额（USDC）
# 建议小额起步（5-20 USDC），验证策略后再逐步增加
TRADE_AMOUNT=5

# 交易分析日志 CSV 文件路径（留空则不记录）
# 示例：./logs/trading_analysis.csv
# 开启后会记录每笔交易的详细分析数据到 CSV，用于复盘
TRADING_ANALYSIS_LOG=


# ── 开仓条件参数 ────────────────────────────────────────────────────────────
# 系统支持 4 组独立开仓条件 (Condition 1~4)，可同时启用多组
# 每组条件均包含三个核心参数：
#   TIME   = K 线回溯时间窗口（秒），在此窗口内分析价差走势
#            - 值越大，需要积累更多 K 线数据才触发
#            - 值越小，响应越快但误触发概率增加
#   DIFF   = 价差变动幅度阈值（基点，1 基点 = 0.01%）
#            - 例如 DIFF=30：15 秒 K 线收盘价差需变化 0.30%
#            - 值越小越容易触发，值越大越保守
#   MIN_PROB / MAX_PROB = 买入时的 YES 代币概率范围
#            - 低于 MIN_PROB 或高于 MAX_PROB 都不会买入
#            - 例如 [0.80, 0.92] 表示只买概率 80%~92% 的市场

# ── 条件 1：默认 120 秒窗口，价差变动 30 基点 ──
CONDITION_1_TIME=120
CONDITION_1_DIFF=30
CONDITION_1_MIN_PROB=0.80
CONDITION_1_MAX_PROB=0.92

# ── 条件 2：默认 120 秒窗口，价差变动 30 基点 ──
CONDITION_2_TIME=120
CONDITION_2_DIFF=30
CONDITION_2_MIN_PROB=0.80
CONDITION_2_MAX_PROB=0.92

# ── 条件 3：默认 60 秒窗口，价差变动 50 基点（更敏感） ──
CONDITION_3_TIME=60
CONDITION_3_DIFF=50
CONDITION_3_MIN_PROB=0.80
CONDITION_3_MAX_PROB=0.92

# ── 条件 4：默认 60 秒窗口，价差变动 50 基点（更敏感） ──
CONDITION_4_TIME=60
CONDITION_4_DIFF=50
CONDITION_4_MIN_PROB=0.80
CONDITION_4_MAX_PROB=0.92


# ── 下单执行参数 ────────────────────────────────────────────────────────────
# 订单超时时间（秒）：超过此时间未成交则取消
# 市场流动性好可设 5-8 秒，流动性差可设 15-30 秒
ORDER_TIMEOUT_SEC=8

# 滑点容忍度（小数）：0.05 = 允许 5% 的价格滑点
# 流动性好的市场可设小（0.02-0.03），流动性差需设大（0.05-0.10）
# 设太大可能导致成交价格不理想
SLIPPAGE_THRESHOLD=0.05

# 每个市场最大下单重试次数（失败后换下一个市场）
MAX_RETRY_PER_MARKET=2

# 买入重试时的价格让步步长：每次重试提高出价
# 0.01 = 每次加价 1%，例如首次 0.90，重试 0.91，再重试 0.92
BUY_RETRY_STEP=0.01


# ── 止损 / 止盈 ─────────────────────────────────────────────────────────────
# 止损概率阈值：当 YES 概率降至此值以下时触发止损卖出
# 0.15 = 价格跌到 15% 概率时止损（默认）
# 0.30 = 更激进的止损（锁住更多利润但容易被波动震出）
STOP_LOSS_PROB_PCT=0.15

# 止盈盈亏比：目标收益率 / 止损损失
# 1.0 = 收益达到止损损失的 1 倍时止盈（1:1 盈亏比）
# 2.0 = 收益达到止损损失的 2 倍时止盈（2:1 盈亏比）
TAKE_PROFIT_RR=1.0

# 止盈概率上限：YES 概率达到此值时强制止盈
# 0.99 = 涨到 99% 必然止盈，不管 RR 是否达标
TAKE_PROFIT_CAP=0.99

# 止盈重试时的价格让步步长
# 0.005 = 每次重试降低出价 0.5%
TAKE_PROFIT_RETRY_STEP=0.005

# 止盈最大重试次数
TAKE_PROFIT_RETRY_MAX=3

# 市场数据最大允许延迟（秒）：超过此值认为数据过期，跳过本轮开仓
# 以太坊/Polygon 网络拥堵时可能需要增大
MARKET_DATA_MAX_LAG_SEC=1.2

# 主循环间隔（秒）：每次循环之间的休眠时间
# 0.25 = 每秒 4 次循环（响应快但 CPU 占用高）
# 1.0  = 每秒 1 次循环（响应慢但省资源）
LOOP_INTERVAL_SEC=0.25

# 检查间隔（秒）：旧参数，目前未使用，保留兼容
CHECK_INTERVAL=2


# ── 自动赎回 (Auto-Redeem) ──────────────────────────────────────────────────
# 是否自动赎回已到期的市场仓位
# 仓位到期后 YES/NO 代币变为 1 USDC = 1 代币，赎回后取回 USDC
AUTO_REDEEM=true

# 扫描可赎回仓位的间隔（秒）：每隔 N 秒检查一次
REDEEM_SCAN_INTERVAL=15

# 赎回失败后的重试间隔（秒）：赎回失败后等待 N 秒再试
REDEEM_RETRY_INTERVAL=120

# 每次扫描最大赎回数量：避免一笔交易赎回太多导致 Gas 过高
REDEEM_MAX_PER_SCAN=2

# 待处理赎回状态的日志输出间隔（秒）：避免频繁打印相同日志
REDEEM_PENDING_LOG_INTERVAL=30


# ── 仪表盘 & Web 服务 ──────────────────────────────────────────────────────
# 启用 Web 仪表盘（访问 http://host:port 查看实时状态）
WEB_ENABLED=true

# 监听地址：0.0.0.0 = 所有网络接口（可被局域网其他设备访问）
# 127.0.0.1 = 仅本机可访问（更安全）
WEB_HOST=0.0.0.0

# 监听端口
WEB_PORT=5080

# 仪表盘账户信息同步间隔（秒）：从链上刷新 USDC 余额和持仓数据
DASHBOARD_ACCOUNT_SYNC_SEC=20


# ── 市场数据刷新 ───────────────────────────────────────────────────────────
# 发现新市场的日志输出间隔（秒）：避免重复日志刷屏
MARKET_FOUND_LOG_INTERVAL=30

# 市场元数据刷新间隔（秒）：刷新市场名称、描述、结束时间等基本信息
MARKET_META_REFRESH_SEC=5


# ── 代理（可选）─────────────────────────────────────────────────────────────
# 如网络需要代理访问 Polygon / Polymarket API 时配置
# 不需要代理则留空
HTTP_PROXY=
HTTPS_PROXY=


# ── Telegram 通知（可选）────────────────────────────────────────────────────
# 注意：当前版本代码未实现 Telegram 通知功能
# 以下变量预留供后续扩展
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── 高级选项 ────────────────────────────────────────────────────────────────
# 私钥对应的钱包地址（可选）
# 用于仪表盘用户身份识别，如果未设置自动从 FUNDER_ADDRESS 或 PRIVATE_KEY 推导
PRIVATE_KEY_ADDRESS=
