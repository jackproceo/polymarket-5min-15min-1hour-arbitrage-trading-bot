# =============================================================================
# docker-compose.env.example
# =============================================================================
# This file is NOT required — each bot reads its own config file directly.
# It exists as a reference for environment variables you might want to set
# globally for all containers (e.g. TZ, http_proxy).
#
# Usage: copy to docker-compose.env and uncomment as needed:
#   cp docker-compose.env.example docker-compose.env
#
# Then in docker-compose.yml, add: env_file: docker-compose.env
# =============================================================================

# Timezone (all 3 bots will use this)
# TZ=Asia/Shanghai

# Global proxy (if VPS requires it)
# HTTP_PROXY=http://proxy:port
# HTTPS_PROXY=http://proxy:port
# NO_PROXY=localhost,127.0.0.1
